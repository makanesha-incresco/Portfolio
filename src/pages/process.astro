---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="How I Work">
    <Navbar active="process" />
    <main class="relative pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto overflow-hidden">
        <!-- Blueprint Background Decoration -->
        <div class="absolute inset-0 blueprint-grid pointer-events-none opacity-20"></div>
        
        <!-- Header Section -->
        <header class="relative mb-24">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div class="max-w-2xl">
                    <span class="font-label text-primary text-xs tracking-[0.3em] uppercase block mb-4">Operational Framework v2.0</span>
                    <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter text-on-surface leading-none mb-6">
                        PRODUCT <br/> <span class="text-primary">STRATEGY.</span>
                    </h1>
                    <p class="text-on-surface/70 text-lg max-w-lg leading-relaxed">
                        I work at the intersection of business, product, and technology, helping translate client requirements into structured digital solutions.
                    </p>
                </div>
                <div class="hidden md:block text-right">
                    <div class="font-label text-on-surface/40 text-[10px] uppercase tracking-widest mb-1">System Status</div>
                    <div class="flex items-center gap-2 justify-end">
                        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                        <span class="font-label text-on-surface text-sm uppercase">Optimizing Flows</span>
                    </div>
                </div>
            </div>
        </header>

        <!-- The 5-Step Process -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-y-12 md:gap-x-12 relative">
            <!-- STEP 1 -->
            <section class="md:col-span-8 group relative">
                <div class="flex items-start gap-6">
                    <span class="font-headline text-6xl font-extrabold text-surface-container-high group-hover:text-primary transition-colors duration-500 opacity-30">01</span>
                    <div class="pt-4">
                        <h2 class="font-headline text-3xl font-bold tracking-tight text-on-surface mb-4">Business Requirement Analysis</h2>
                        <div class="bg-surface-container-low p-8 rounded-sm border-l-2 border-primary relative overflow-hidden">
                            <div class="relative z-10">
                                <p class="text-on-surface/70 mb-6 leading-relaxed">
                                    I work closely with clients to thoroughly understand business problems, identifying the core constraints and context before shaping execution.
                                </p>
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="flex flex-col">
                                        <span class="font-label text-[10px] text-primary uppercase tracking-widest mb-2">Input Matrix</span>
                                        <ul class="text-xs space-y-1 text-on-surface/50">
                                            <li>Stakeholder Interviews</li>
                                            <li>Revenue Leakage Mapping</li>
                                            <li>Operational Audits</li>
                                        </ul>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-label text-[10px] text-primary uppercase tracking-widest mb-2">Artifact</span>
                                        <span class="text-sm font-medium text-on-surface">Functional Requirements Doc</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <div class="hidden md:flex md:col-span-4 justify-center items-center">
                <span class="material-symbols-outlined text-8xl text-surface-container-high opacity-20">query_stats</span>
            </div>

            <!-- STEP 2 -->
            <div class="hidden md:block md:col-span-4"></div>
            <section class="md:col-span-8 group relative">
                <div class="flex items-start gap-6">
                    <span class="font-headline text-6xl font-extrabold text-surface-container-high group-hover:text-primary transition-colors duration-500 opacity-30">02</span>
                    <div class="pt-4">
                        <h2 class="font-headline text-3xl font-bold tracking-tight text-on-surface mb-4">Structure Product Approaches</h2>
                        <div class="bg-surface-container-low p-8 rounded-sm border-l-2 border-primary">
                            <p class="text-on-surface/70 mb-6 font-light leading-relaxed">
                                Mapping logic to solutions. I structure product approaches that align tightly with both overarching business goals and technical feasibility.
                            </p>
                            <div class="bg-surface-container-high p-4 border border-outline-variant/15 rounded-sm">
                                <div class="flex items-center gap-3 mb-4">
                                    <span class="material-symbols-outlined text-primary">account_tree</span>
                                    <span class="font-label text-xs uppercase tracking-tighter text-on-surface">Data Flow Visualization</span>
                                </div>
                                <div class="space-y-3">
                                    <div class="h-1 bg-background rounded-full overflow-hidden">
                                        <div class="h-full bg-primary w-[75%]"></div>
                                    </div>
                                    <div class="flex justify-between text-[10px] font-label text-on-surface/40 uppercase">
                                        <span>CRM Data Source</span>
                                        <span>API Gateway</span>
                                        <span>UI Frontend</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- STEP 3 -->
            <section class="md:col-span-12 group">
                <div class="flex flex-col md:flex-row gap-8 items-center bg-surface-container-low/50 p-12 rounded-sm border border-outline-variant/10">
                    <div class="md:w-1/3">
                        <span class="font-headline text-8xl font-extrabold text-primary/10 block leading-none">03</span>
                        <h2 class="font-headline text-4xl font-bold tracking-tight text-on-surface mt-[-2rem]">Strategy & MVP Definition</h2>
                    </div>
                    <div class="md:w-2/3">
                        <p class="text-on-surface/70 text-lg mb-6 leading-relaxed font-light">
                            Shaping product direction. I define clear execution paths out of ambiguity, distilling complex requirements into a streamlined MVP.
                        </p>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                            <div class="p-4 bg-surface-container-high border-b-2 border-primary">
                                <span class="material-symbols-outlined text-primary mb-2">grid_view</span>
                                <h4 class="font-label text-sm font-bold text-on-surface uppercase mb-1">Discovery</h4>
                                <p class="text-xs text-on-surface/40">Requirement Synthesis.</p>
                            </div>
                            <div class="p-4 bg-surface-container-high border-b-2 border-primary">
                                <span class="material-symbols-outlined text-primary mb-2">touch_app</span>
                                <h4 class="font-label text-sm font-bold text-on-surface uppercase mb-1">Definition</h4>
                                <p class="text-xs text-on-surface/40">Defining the MVP scope.</p>
                            </div>
                            <div class="p-4 bg-surface-container-high border-b-2 border-primary">
                                <span class="material-symbols-outlined text-primary mb-2">architecture</span>
                                <h4 class="font-label text-sm font-bold text-on-surface uppercase mb-1">Roadmap</h4>
                                <p class="text-xs text-on-surface/40">Clear execution paths.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- STEP 4 -->
            <section class="md:col-span-7 group relative">
                <div class="flex items-start gap-6">
                    <span class="font-headline text-6xl font-extrabold text-surface-container-high group-hover:text-primary transition-colors duration-500 opacity-30">04</span>
                    <div class="pt-4">
                        <h2 class="font-headline text-3xl font-bold tracking-tight text-on-surface mb-4">Ship Early Versions</h2>
                        <div class="bg-surface-container-low p-8 rounded-sm border-l-2 border-primary">
                            <p class="text-on-surface/70 mb-8 leading-relaxed font-light">
                                I work tightly with teams to ship early versions that prioritize delivering immediate business value and meaningful outcomes over purely technical features.
                            </p>
                            <div class="space-y-4">
                                <div class="flex items-start gap-4 p-4 bg-surface-container-high/60 border border-outline-variant/15">
                                    <span class="material-symbols-outlined text-primary bg-primary/10 p-2 rounded">hub</span>
                                    <div>
                                        <h4 class="font-label text-xs text-primary font-bold uppercase tracking-widest mb-1">Featured Engagement: Enterprise Client</h4>
                                        <p class="text-sm text-on-surface font-medium mb-1">Core Product Strategy & MVP Launch</p>
                                        <p class="text-xs text-on-surface/50">Redefined the product roadmap to align with clear business metrics, successfully launching a highly validated MVP.</p>
                                    </div>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-2 py-1 bg-surface-container-high text-[10px] font-label text-on-surface uppercase border border-outline-variant/20">Product Strategy</span>
                                    <span class="px-2 py-1 bg-surface-container-high text-[10px] font-label text-on-surface uppercase border border-outline-variant/20">MVP Execution</span>
                                    <span class="px-2 py-1 bg-surface-container-high text-[10px] font-label text-on-surface uppercase border border-outline-variant/20">Client Discovery</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- STEP 5 -->
            <section class="md:col-span-5 group relative">
                <div class="flex items-start gap-6">
                    <span class="font-headline text-6xl font-extrabold text-surface-container-high group-hover:text-emerald-400 transition-colors duration-500 opacity-30">05</span>
                    <div class="pt-4">
                        <h2 class="font-headline text-3xl font-bold tracking-tight text-on-surface mb-4">Shape Organizational Growth</h2>
                        <div class="bg-surface-container-low p-8 rounded-sm border-l-2 border-emerald-400 shadow-[0_0_30px_rgba(52,211,153,0.05)]">
                            <p class="text-on-surface/70 mb-6 font-light leading-relaxed">
                                Looking beyond the immediate product. Contributing to broader organizational growth by identifying, validating, and shaping entirely new market opportunities.
                            </p>
                            <div class="space-y-4">
                                <div class="flex items-center justify-between border-b border-outline-variant/10 pb-2">
                                    <span class="text-xs font-label uppercase text-on-surface/40">MVP Time-to-Market</span>
                                    <span class="text-lg font-bold text-emerald-400">8 Weeks</span>
                                </div>
                                <div class="flex items-center justify-between border-b border-outline-variant/10 pb-2">
                                    <span class="text-xs font-label uppercase text-on-surface/40">User Adoption</span>
                                    <span class="text-lg font-bold text-emerald-400">+35%</span>
                                </div>
                            </div>
                            <div class="mt-8 flex justify-center">
                                <span class="material-symbols-outlined text-4xl text-emerald-400/40 animate-bounce">trending_up</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- Decor -->
        <div class="mt-32 flex items-center gap-4 opacity-30">
            <div class="h-[1px] flex-grow bg-outline-variant"></div>
            <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">circle</span>
            <div class="h-[1px] w-12 bg-primary"></div>
            <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">circle</span>
            <div class="h-[1px] w-24 bg-primary"></div>
            <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">circle</span>
            <div class="h-[1px] flex-grow bg-outline-variant"></div>
        </div>
    </main>
    <Footer />
</BaseLayout>
