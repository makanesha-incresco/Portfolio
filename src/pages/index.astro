<script>
    // Experience Switcher
    const buttons = document.querySelectorAll('.exp-btn');
    const contents = document.querySelectorAll('.exp-content');
    
    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
            const role = btn.id.replace('show-', '');
            
            // Toggle visibility
            contents.forEach(content => {
                if (content.id === `exp-${role}`) {
                    content.classList.remove('hidden');
                    content.classList.add('block');
                } else {
                    content.classList.remove('block');
                    content.classList.add('hidden');
                }
            });
            
            // Toggle active state
            buttons.forEach(b => {
                b.classList.remove('bg-primary/10', 'text-primary', 'border-primary');
                b.classList.add('text-on-surface/50', 'border-transparent');
            });
            btn.classList.add('bg-primary/10', 'text-primary', 'border-primary');
            btn.classList.remove('text-on-surface/50', 'border-transparent');
        });
    });

    // Typewriter Effect
    const phrases = ["BUSINESS IMPACT.", "PRODUCT STRATEGY.", "SCALABLE SOLUTIONS.", "METRIC GROWTH."];
    let phraseIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let isEnd = false;

    function typewriterLoop() {
        isEnd = false;
        const typewriterEl = document.getElementById('typewriter');
        if (!typewriterEl) return;
        
        const currentFullPhrase = phrases[phraseIndex];
        
        if (!isDeleting) {
            typewriterEl.textContent = currentFullPhrase.substring(0, charIndex + 1);
            charIndex++;
            if (charIndex === currentFullPhrase.length) {
                isEnd = true;
                isDeleting = true;
            }
        } else {
            typewriterEl.textContent = currentFullPhrase.substring(0, charIndex - 1);
            charIndex--;
            if (charIndex === 0) {
                isDeleting = false;
                phraseIndex = (phraseIndex + 1) % phrases.length;
            }
        }
        
        const speed = isEnd ? 2000 : isDeleting ? 50 : 100;
        setTimeout(typewriterLoop, speed);
    }
    setTimeout(typewriterLoop, 1500);
</script>
