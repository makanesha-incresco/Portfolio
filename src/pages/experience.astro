---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Professional Experience">
    <Navbar active="experience" />
    <main class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto blueprint-grid min-h-screen">
        <header class="mb-24 flex flex-col md:flex-row justify-between items-end gap-8 border-l-2 border-primary pl-8">
            <div class="max-w-2xl">
                <div class="font-label text-primary text-xs tracking-[0.3em] uppercase mb-4">Registry // Professional Trace Log</div>
                <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter text-on-surface leading-none mb-6">
                    CAREER <br/> <span class="text-primary-container">ARCHITECTURE</span>
                </h1>
                <p class="text-on-surface/70 text-lg max-w-lg leading-relaxed font-light">
                    A technical timeline mapping my journey from core engineering to strategic product analysis and business growth.
                </p>
            </div>
            <div class="text-right hidden md:block">
                <div class="font-label text-on-surface/40 text-[10px] tracking-widest uppercase mb-1">Status: Verified</div>
                <div class="font-label text-on-surface text-xs font-mono">LOG_VERSION_2.4.0</div>
            </div>
        </header>

        <!-- Experience Content -->
        <div class="grid md:grid-cols-4 gap-0 border border-outline-variant/30 overflow-hidden rounded-xl bg-surface/50 backdrop-blur-sm">
            <div class="md:col-span-1 bg-surface-container-low border-r border-outline-variant/30 overflow-y-auto max-h-[800px]">
                <div class="p-8">
                    <div class="mb-4">
                        <h3 class="font-headline font-bold text-lg text-primary mb-1">Incresco</h3>
                        <p class="text-[10px] font-label text-on-surface/40 tracking-widest uppercase">Professional</p>
                    </div>
                    <nav class="space-y-2 mb-8">
                        <button id="show-ba" class="exp-btn w-full text-left p-4 bg-primary/10 text-primary border-l-4 border-primary transition-all flex items-center justify-between group">
                            <span class="font-label text-xs uppercase font-bold">Business Analyst</span>
                            <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">insights</span>
                        </button>
                        <button id="show-se" class="exp-btn w-full text-left p-4 hover:bg-surface-container-high/50 text-on-surface/50 hover:text-on-surface transition-all flex items-center justify-between group border-l-4 border-transparent">
                            <span class="font-label text-xs uppercase">Software Engineer</span>
                            <span class="material-symbols-outlined text-sm">terminal</span>
                        </button>
                    </nav>

                    <div class="mb-4">
                        <h3 class="font-headline font-bold text-lg text-primary mb-1">Campus Life</h3>
                        <p class="text-[10px] font-label text-on-surface/40 tracking-widest uppercase">Leadership</p>
                    </div>
                    <nav class="space-y-2 mb-8">
                        <button id="show-leader" class="exp-btn w-full text-left p-4 hover:bg-surface-container-high/50 text-on-surface/50 hover:text-on-surface transition-all flex items-center justify-between group border-l-4 border-transparent">
                            <span class="font-label text-xs uppercase">Co-Curricular</span>
                            <span class="material-symbols-outlined text-sm">groups_2</span>
                        </button>
                    </nav>

                    <div class="mb-4">
                        <h3 class="font-headline font-bold text-lg text-primary mb-1">Education</h3>
                        <p class="text-[10px] font-label text-on-surface/40 tracking-widest uppercase">Academic</p>
                    </div>
                    <nav class="space-y-2 mb-8">
                        <button id="show-edu" class="exp-btn w-full text-left p-4 hover:bg-surface-container-high/50 text-on-surface/50 hover:text-on-surface transition-all flex items-center justify-between group border-l-4 border-transparent">
                            <span class="font-label text-xs uppercase">Academic Profile</span>
                            <span class="material-symbols-outlined text-sm">history_edu</span>
                        </button>
                    </nav>

                    <div class="mb-4">
                        <h3 class="font-headline font-bold text-lg text-primary mb-1">Infosys</h3>
                        <p class="text-[10px] font-label text-on-surface/40 tracking-widest uppercase">R&D</p>
                    </div>
                    <nav class="space-y-2">
                        <button id="show-ai" class="exp-btn w-full text-left p-4 hover:bg-surface-container-high/50 text-on-surface/50 hover:text-on-surface transition-all flex items-center justify-between group border-l-4 border-transparent">
                            <span class="font-label text-xs uppercase">AI Intern</span>
                            <span class="material-symbols-outlined text-sm">smart_toy</span>
                        </button>
                    </nav>
                </div>
            </div>
            <div class="md:col-span-3 p-8 md:p-12 bg-surface overflow-y-auto max-h-[800px]">
                <!-- Business Analyst Content -->
                <div id="exp-ba" class="exp-content block animate-fade-in">
                    <div class="flex flex-col md:flex-row justify-between items-start mb-10 gap-4">
                        <div>
                            <span class="text-secondary font-label text-xs uppercase tracking-widest flex items-center gap-2">
                                <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                                Currently Leading: Business & Growth
                            </span>
                            <h3 class="font-headline text-4xl font-bold mt-2">Business Analyst</h3>
                            <p class="text-on-surface/60 mt-1 italic">Nov 2025 — Present</p>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-label uppercase border border-primary/20">Product Envisioning</span>
                            <span class="px-3 py-1 bg-secondary/10 text-secondary text-[10px] font-label uppercase border border-secondary/20">Growth Strategy</span>
                            <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-label uppercase border border-primary/20">Business Dev</span>
                        </div>
                    </div>
                    <div class="space-y-8">
                        <p class="text-on-surface/70 leading-relaxed font-light text-lg">
                            Translating ambiguous client needs into high-growth digital products. Strategic partner for a **Luxury European Hospitality brand**, focusing on requirement framing and product discovery.
                        </p>
                        
                        <div class="grid md:grid-cols-2 gap-8">
                            <div class="space-y-6">
                                <div class="relative pl-8 border-l border-secondary/20 group">
                                    <span class="absolute -left-1.5 top-0 w-3 h-3 bg-secondary rounded-full blur-[2px] opacity-40 group-hover:opacity-100 transition-opacity"></span>
                                    <h4 class="font-label text-[10px] text-secondary tracking-widest uppercase mb-3">Core Responsibilities</h4>
                                    <ul class="space-y-4">
                                        <li class="flex gap-4 group/item">
                                            <span class="material-symbols-outlined text-secondary text-lg">check_circle</span>
                                            <p class="text-sm leading-relaxed text-on-surface/80 group-hover/item:text-on-surface transition-colors">Requirement framing and product envisioning for multi-million dollar hospitality projects.</p>
                                        </li>
                                        <li class="flex gap-4 group/item">
                                            <span class="material-symbols-outlined text-secondary text-lg">check_circle</span>
                                            <p class="text-sm leading-relaxed text-on-surface/80 group-hover/item:text-on-surface transition-colors">Structuring complex CRM systems and defining AI application layers for elite brands.</p>
                                        </li>
                                        <li class="flex gap-4 group/item">
                                            <span class="material-symbols-outlined text-secondary text-lg">check_circle</span>
                                            <p class="text-sm leading-relaxed text-on-surface/80 group-hover/item:text-on-surface transition-colors">Leading MVP definition and technical feasibility studies for enterprise-tier clients.</p>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            
                            <div class="glass-card p-8 border-primary/10 bg-primary/[0.02]">
                                <h4 class="font-headline font-bold text-xs text-primary uppercase tracking-widest mb-6">Current Objective</h4>
                                <p class="text-sm text-on-surface/70 leading-relaxed font-light mb-6">
                                    Actively contributing to **pulling new business opportunities** into the organisation by aligning client vision with technical excellence.
                                </p>
                                <div class="flex gap-4">
                                    <div class="flex-1">
                                        <div class="text-[10px] font-label uppercase text-on-surface/40 mb-1">Growth Acquisition</div>
                                        <div class="h-[2px] w-full bg-outline-variant/30"><div class="h-full bg-primary w-[85%]"></div></div>
                                    </div>
                                    <div class="flex-1">
                                        <div class="text-[10px] font-label uppercase text-on-surface/40 mb-1">Business Strategy</div>
                                        <div class="h-[2px] w-full bg-outline-variant/30"><div class="h-full bg-primary w-[95%]"></div></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Software Engineer Content -->
                <div id="exp-se" class="exp-content hidden animate-fade-in">
                    <div class="flex flex-col md:flex-row justify-between items-start mb-10 gap-4">
                        <div>
                            <h3 class="font-headline text-4xl font-bold mt-2">Software Engineer Intern</h3>
                            <p class="text-on-surface/60 mt-1 italic">Jul 2025 — Nov 2025</p>
                        </div>
                        <div class="flex flex-wrap gap-2">
                             <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-label uppercase border border-primary/20 tracking-tighter">Medusa.js</span>
                            <span class="px-3 py-1 bg-secondary/10 text-secondary text-[10px] font-label uppercase border border-secondary/20 tracking-tighter">ETL Node.js</span>
                            <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-label uppercase border border-primary/20 tracking-tighter">React</span>
                        </div>
                    </div>
                    <div class="grid md:grid-cols-2 gap-12">
                        <div>
                            <h4 class="font-label text-[10px] text-primary tracking-widest uppercase mb-6">Technical Objectives</h4>
                            <ul class="space-y-6">
                                <li class="flex gap-4">
                                    <span class="material-symbols-outlined text-primary text-xl">database</span>
                                    <div class="space-y-1">
                                        <p class="text-sm font-bold">Data Migration ETL</p>
                                        <p class="text-xs text-on-surface/60 leading-relaxed">Built complex automated ETL pipelines for Salesforce customer object migration to Medusa.js.</p>
                                    </div>
                                </li>
                                <li class="flex gap-4">
                                    <span class="material-symbols-outlined text-primary text-xl">shopping_cart</span>
                                    <div class="space-y-1">
                                        <p class="text-sm font-bold">Commerce Architecture</p>
                                        <p class="text-xs text-on-surface/60 leading-relaxed">Developed and customized Medusa.js backend modules for specialized B2B and retail flows.</p>
                                    </div>
                                </li>
                            </ul>
                        </div>
                        <div class="glass-card p-8 border-primary/10">
                            <h4 class="font-headline font-bold text-xs text-secondary uppercase tracking-widest mb-4">Tech Arsenal</h4>
                            <div class="flex flex-wrap gap-2">
                                <span class="px-2 py-1 bg-surface-container text-[10px] font-label text-on-surface uppercase border border-outline-variant/20">Node.js</span>
                                <span class="px-2 py-1 bg-surface-container text-[10px] font-label text-on-surface uppercase border border-outline-variant/20">React.js</span>
                                <span class="px-2 py-1 bg-surface-container text-[10px] font-label text-on-surface uppercase border border-outline-variant/20">Medusa.js</span>
                                <span class="px-2 py-1 bg-surface-container text-[10px] font-label text-on-surface uppercase border border-outline-variant/20">PostgreSQL</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Academic Profile Content -->
                <div id="exp-edu" class="exp-content hidden animate-fade-in">
                    <div class="flex items-center gap-4 mb-10">
                        <h3 class="font-headline text-4xl font-bold">Academic Profile</h3>
                        <div class="h-[1px] flex-grow bg-outline-variant/20"></div>
                        <span class="font-label text-[10px] text-primary uppercase tracking-[0.2em]">Verified Transcript</span>
                    </div>
                    
                    <div class="space-y-12">
                         <!-- Master's -->
                        <div class="relative pl-12 border-l border-primary/20 pb-12">
                            <span class="absolute -left-[5px] top-0 w-2.5 h-2.5 bg-primary rounded-full ring-4 ring-primary/10"></span>
                            <div class="flex flex-col md:flex-row justify-between items-start gap-4 mb-4">
                                <div>
                                    <h4 class="text-2xl font-headline font-bold text-on-surface">Kongu Engineering College</h4>
                                    <p class="text-secondary font-label text-sm">Master's Degree, Software Systems</p>
                                </div>
                                <div class="text-right">
                                    <div class="px-4 py-2 bg-primary/10 border border-primary/20 rounded-sm">
                                        <div class="text-primary font-headline font-bold text-xl leading-none">8.85</div>
                                        <div class="text-[8px] font-label uppercase tracking-widest mt-1">Current Grade</div>
                                    </div>
                                </div>
                            </div>
                            <p class="text-xs font-label text-on-surface/50 mb-6 uppercase tracking-widest">Jun 2022 — May 2027</p>
                            
                            <h5 class="text-[10px] font-label uppercase text-primary tracking-widest mb-4">Acquired Competencies</h5>
                            <div class="flex flex-wrap gap-2">
                                {['React.js', 'Python', 'Web Development', 'Tailwind CSS', 'Google Cloud Platform (GCP)', 'Deep Learning', 'C++', 'Bootstrap', 'Figma', 'HTML5', 'WordPress'].map(skill => (
                                    <span class="px-3 py-1 bg-surface-container-high/40 text-[10px] font-label rounded-sm border border-outline-variant/20 text-on-surface/70">{skill}</span>
                                ))}
                            </div>
                        </div>

                        <!-- HSLC -->
                        <div class="relative pl-12 border-l border-outline-variant/20 pb-12">
                            <span class="absolute -left-[5px] top-0 w-2.5 h-2.5 bg-outline-variant rounded-full"></span>
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <h4 class="text-xl font-headline font-bold text-on-surface/80">Bharathi Vidhya Bhavan</h4>
                                    <p class="text-on-surface/50 font-label text-sm">HSLC (High School Leaving Certificate)</p>
                                    <p class="text-xs font-label text-on-surface/40 mt-1 uppercase tracking-widest">Jul 2020 — Jun 2022</p>
                                </div>
                                <div class="text-right">
                                    <span class="text-2xl font-headline font-bold text-on-surface/50">86.6%</span>
                                    <p class="text-[8px] font-label uppercase text-on-surface/30">Grade 12</p>
                                </div>
                            </div>
                        </div>

                        <!-- SSLC -->
                        <div class="relative pl-12 border-l border-outline-variant/20">
                            <span class="absolute -left-[5px] top-0 w-2.5 h-2.5 bg-outline-variant rounded-full"></span>
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <h4 class="text-xl font-headline font-bold text-on-surface/80">Shri Vethathiri Vidhyalaya</h4>
                                    <p class="text-on-surface/50 font-label text-sm">SSLC (Secondary School Leaving Certificate)</p>
                                    <p class="text-xs font-label text-on-surface/40 mt-1 uppercase tracking-widest">Graduated Jun 2020</p>
                                </div>
                                <div class="text-right">
                                    <span class="text-2xl font-headline font-bold text-on-surface/50">98.8%</span>
                                    <p class="text-[8px] font-label uppercase text-on-surface/30">Grade 10</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Campus Leadership Content -->
                <div id="exp-leader" class="exp-content hidden animate-fade-in">
                    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
                         <h3 class="font-headline text-4xl font-bold">Campus Leadership</h3>
                         <span class="font-label text-[10px] text-secondary tracking-widest uppercase">CO-CURRICULAR LOGS</span>
                    </div>

                    <div class="space-y-12">
                        <!-- Association CT-PG -->
                        <div class="glass-card p-10 border-primary/20 bg-primary/[0.01] relative group overflow-hidden">
                             <div class="absolute top-0 right-0 p-4 opacity-[0.05] group-hover:opacity-10 transition-opacity">
                                <span class="material-symbols-outlined text-8xl text-primary">diversity_3</span>
                            </div>
                            <h4 class="text-2xl font-headline font-bold text-on-surface mb-2">Association of CT-PG</h4>
                            <p class="text-primary font-label text-xs uppercase tracking-widest mb-8">Kongu Engineering College</p>
                            
                            <div class="space-y-8">
                                <div class="relative pl-10 border-l border-primary/20">
                                    <span class="absolute -left-[4px] top-0 w-2 h-2 bg-primary rounded-full"></span>
                                    <h5 class="text-lg font-bold">Additional Secretary</h5>
                                    <p class="text-xs text-on-surface/50 italic mb-2">Aug 2024 — Jun 2025</p>
                                    <p class="text-sm text-on-surface/70 font-light">Privileged to hold a major leadership position, overseeing association operations and strategic planning.</p>
                                </div>
                                <div class="relative pl-10 border-l border-primary/20">
                                    <span class="absolute -left-[4px] top-0 w-2 h-2 bg-primary/40 rounded-full"></span>
                                    <h5 class="text-on-surface/80 font-bold">Student Member</h5>
                                    <p class="text-xs text-on-surface/40 mb-2 italic">Aug 2022 — Aug 2024</p>
                                </div>
                            </div>
                        </div>

                         <!-- Self Development Club -->
                         <div class="glass-card p-10 border-secondary/20 bg-secondary/[0.01] relative group overflow-hidden">
                            <div class="absolute top-0 right-0 p-4 opacity-[0.05] group-hover:opacity-10 transition-opacity">
                                <span class="material-symbols-outlined text-8xl text-secondary">psychology</span>
                            </div>
                            <h4 class="text-2xl font-headline font-bold text-on-surface mb-2">Self Development Club KEC</h4>
                            <p class="text-secondary font-label text-xs uppercase tracking-widest mb-8">Student Empowerment</p>
                            
                            <div class="space-y-8">
                                <div class="relative pl-10 border-l border-secondary/20">
                                    <span class="absolute -left-[4px] top-0 w-2 h-2 bg-secondary rounded-full"></span>
                                    <h5 class="text-lg font-bold">Executive Member</h5>
                                    <p class="text-xs text-on-surface/50 italic mb-2">Aug 2024 — Jun 2025</p>
                                    <p class="text-sm text-on-surface/70 font-light mb-4">Contributed to various events across technical, multimedia, MOC, and documentation teams.</p>
                                    <div class="flex flex-wrap gap-2">
                                        {['Poster Design', 'Organization', 'Multi-media', 'MOC', 'Documentation'].map(skill => (
                                            <span class="text-[9px] font-label px-2 py-0.5 bg-secondary/10 text-secondary border border-secondary/20 rounded-full">{skill}</span>
                                        ))}
                                    </div>
                                </div>
                                <div class="relative pl-10 border-l border-secondary/20">
                                    <span class="absolute -left-[4px] top-0 w-2 h-2 bg-secondary/40 rounded-full"></span>
                                    <h5 class="text-on-surface/80 font-bold">Student Member</h5>
                                    <p class="text-xs text-on-surface/40 mb-2 italic">Aug 2023 — Aug 2024</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- AI Intern Content -->
                <div id="exp-ai" class="exp-content hidden animate-fade-in">
                    <div class="flex flex-col md:flex-row justify-between items-start mb-10 gap-4">
                        <div>
                            <h3 class="font-headline text-4xl font-bold mt-2">AI Intern</h3>
                            <p class="text-on-surface/60 mt-1 italic">Dec 2024 — Feb 2025</p>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-label uppercase border border-primary/20">NLP</span>
                            <span class="px-3 py-1 bg-secondary/10 text-secondary text-[10px] font-label uppercase border border-secondary/20">ML Orchestration</span>
                        </div>
                    </div>
                    <div class="grid md:grid-cols-2 gap-12">
                        <div>
                            <h4 class="font-label text-[10px] text-secondary tracking-widest uppercase mb-6 flex items-center gap-2">
                                <span class="h-[1px] w-4 bg-secondary/40"></span>
                                R&D Parameters
                            </h4>
                            <ul class="space-y-4">
                                <li class="flex gap-4">
                                    <span class="material-symbols-outlined text-secondary text-xl">smart_toy</span>
                                    <p class="text-sm leading-relaxed text-on-surface/80">Developed intent-driven conversational agents for educational data sets.</p>
                                </li>
                            </ul>
                        </div>
                        <div class="glass-card p-8 border-secondary/20 bg-secondary/[0.02]">
                             <p class="text-xs text-on-surface/50 font-mono italic">// Logic processed: Rasa, Streamlit, Python</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>

<script>
    const buttons = document.querySelectorAll('.exp-btn');
    const contents = document.querySelectorAll('.exp-content');

    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
            // Reset buttons
            buttons.forEach(b => {
                b.classList.remove('bg-primary/10', 'text-primary', 'border-primary');
                b.classList.add('text-on-surface/50', 'border-transparent');
                b.querySelector('.font-bold')?.classList.remove('font-bold');
            });

            // Active button
            btn.classList.add('bg-primary/10', 'text-primary', 'border-primary');
            btn.classList.remove('text-on-surface/50', 'border-transparent');
            
            // Switch content
            const target = btn.id.split('-')[1];
            contents.forEach(content => {
                content.classList.add('hidden');
                if (content.id === `exp-${target}`) {
                    content.classList.remove('hidden');
                }
            });
        });
    });
</script>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out forwards;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
