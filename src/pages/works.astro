---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="My Works | BA & Growth">
    <Navbar active="works" />
    <main class="pt-32">
        <!-- Hero Section -->
        <section class="px-8 max-w-7xl mx-auto mb-24">
            <div class="max-w-4xl">
                <span class="inline-flex items-center gap-2 px-3 py-1 bg-primary/10 border border-primary/20 rounded-sm font-label text-[10px] uppercase tracking-[0.2em] text-primary mb-6 animate-fade-up">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                    Strategic Logic & Scale
                </span>
                <h1 class="font-headline text-6xl md:text-8xl font-bold tracking-tighter text-on-background mb-8 leading-[0.9] animate-fade-up delay-100">
                    MY <br/> <span class="text-gradient-vibrant">STRATEGIC WORKS.</span>
                </h1>
                <p class="text-xl text-on-surface/60 max-w-2xl font-light leading-relaxed animate-fade-up delay-200">
                    A deep dive into how I approach business challenges—transforming ambiguous client requirements into high-growth digital systems and measurable revenue impact.
                </p>
            </div>
        </section>        <!-- BA Section -->
        <section class="py-24 bg-surface-container-low/30 border-y border-outline-variant/30 overflow-hidden relative">
            <div class="max-w-7xl mx-auto px-8 relative z-10">
                <div class="grid lg:grid-cols-2 gap-16 items-center">
                    <div>
                        <h2 class="font-headline text-4xl font-bold mb-6 tracking-tight">Requirement Framing & <br/><span class="text-primary">Product Envisioning</span></h2>
                        <p class="text-on-surface/70 leading-relaxed mb-10 font-light text-lg">
                            Collaborated with a **top-tier luxury European hospitality brand** to translate high-level vision into structured product requirements. I bridge the gap between elite client expectations and technical execution.
                        </p>
                        
                        <div class="space-y-6">
                            <div class="glass-card p-6 flex gap-6 items-start hover:border-primary/40 transition-all group">
                                <span class="material-symbols-outlined text-primary text-3xl bg-primary/10 p-2 rounded-sm group-hover:scale-110 transition-transform">auto_awesome</span>
                                <div>
                                    <h3 class="font-headline font-bold text-xl mb-1">AI Application Strategy</h3>
                                    <p class="text-on-surface/60 text-sm italic">Identifying and implementing AI-driven efficiencies for premium service delivery.</p>
                                </div>
                            </div>
                            <div class="glass-card p-6 flex gap-6 items-start hover:border-primary/40 transition-all group">
                                <span class="material-symbols-outlined text-primary text-3xl bg-primary/10 p-2 rounded-sm group-hover:scale-110 transition-transform">contact_page</span>
                                <div>
                                    <h3 class="font-headline font-bold text-xl mb-1">CRM System Structuring</h3>
                                    <p class="text-on-surface/60 text-sm italic">Designing the underlying logic for complex CRM systems tailored to hospitality scale.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="relative group">
                        <div class="absolute -inset-4 border border-primary/20 scale-[1.02] transition-transform group-hover:scale-[1.05]"></div>
                        <div class="absolute -inset-1 bg-gradient-to-r from-primary to-transparent opacity-10 blur-xl"></div>
                        <img src="/works/analysis.png" class="relative z-10 w-full h-auto grayscale group-hover:grayscale-0 transition-all duration-700" alt="Architecture & Planning" />
                    </div>
                </div>
            </div>
        </section>

        <!-- Growth Section -->
        <section class="py-24 px-8 max-w-7xl mx-auto">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="order-2 lg:order-1 relative group">
                    <div class="absolute -inset-4 border border-secondary/20 scale-[1.02] transition-transform group-hover:scale-[1.05]"></div>
                    <img src="/works/growth.png" class="relative z-10 w-full h-auto grayscale group-hover:grayscale-0 transition-all duration-700" alt="Business Development" />
                </div>
                
                <div class="order-1 lg:order-2">
                    <h2 class="font-headline text-4xl font-bold mb-6 tracking-tight">Business Development & <br/><span class="text-secondary">Growth Acquisition</span></h2>
                    <p class="text-on-surface/70 leading-relaxed mb-10 font-light text-lg">
                        Currently focused on identifying and acquiring **new business opportunities**. I utilize my technical background to demonstrate value and scale, turning initial conversations into long-term strategic partnerships.
                    </p>
                    
                    <div class="grid md:grid-cols-2 gap-4">
                        <div class="p-6 bg-surface-container-high/20 border border-outline-variant/30 rounded-sm">
                            <div class="text-3xl font-headline font-bold text-secondary mb-2">MVP</div>
                            <div class="text-xs font-label uppercase tracking-widest text-on-surface/40">From Concept to Scale</div>
                        </div>
                         <div class="p-6 bg-surface-container-high/20 border border-outline-variant/30 rounded-sm">
                            <div class="text-3xl font-headline font-bold text-secondary mb-2">CRM</div>
                            <div class="text-xs font-label uppercase tracking-widest text-on-surface/40">Structured Logic</div>
                        </div>
                         <div class="p-6 bg-surface-container-high/20 border border-outline-variant/30 rounded-sm">
                            <div class="text-3xl font-headline font-bold text-secondary mb-2">Growth</div>
                            <div class="text-xs font-label uppercase tracking-widest text-on-surface/40">Business Dev Focus</div>
                        </div>
                         <div class="p-6 bg-surface-container-high/20 border border-outline-variant/30 rounded-sm">
                            <div class="text-3xl font-headline font-bold text-secondary mb-2">Logic</div>
                            <div class="text-xs font-label uppercase tracking-widest text-on-surface/40">BA Excellence</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
>

        <!-- CTA Section -->
        <section class="py-32 px-8 bg-surface-container-low/50">
            <div class="max-w-4xl mx-auto text-center">
                 <h2 class="font-headline text-5xl md:text-6xl font-bold mb-10 tracking-tighter">Ready to scale your <span class="text-primary italic">impact?</span></h2>
                <a href="/#contact" class="inline-block text-gradient-vibrant px-12 py-5 font-headline font-bold rounded-sm uppercase tracking-[0.2em] border border-primary/30 hover:bg-primary/5 hover:scale-105 transition-all">Let's strategize</a>
            </div>
        </section>
    </main>
    <Footer />
</BaseLayout>
