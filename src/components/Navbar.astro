---
const { active = 'home' } = Astro.props;
---
<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-8 py-4 bg-[#0b1326]/80 backdrop-blur-xl border-b border-outline-variant/20">
    <div class="flex justify-between items-center w-full max-w-7xl mx-auto">
        <div class="text-xl font-bold tracking-tighter text-[#38bdf8] font-['Space_Grotesk'] uppercase">MAKANESHA_V</div>
        <div class="hidden md:flex gap-8 items-center">
            <a class={`font-['Space_Grotesk'] tracking-tighter uppercase text-sm ${active === 'home' ? 'text-primary border-b-2 border-primary pb-1' : 'text-[#dae2fd]/60 hover:text-[#dae2fd] transition-colors'}`} href="/">Home</a>
            <a class={`font-['Space_Grotesk'] tracking-tighter uppercase text-sm ${active === 'experience' ? 'text-primary border-b-2 border-primary pb-1' : 'text-[#dae2fd]/60 hover:text-[#dae2fd] transition-colors'}`} href="/#experience">Experience</a>
            <a class={`font-['Space_Grotesk'] tracking-tighter uppercase text-sm ${active === 'works' ? 'text-primary border-b-2 border-primary pb-1' : 'text-[#dae2fd]/60 hover:text-[#dae2fd] transition-colors'}`} href="/works">Works</a>
            <a class={`font-['Space_Grotesk'] tracking-tighter uppercase text-sm ${active === 'process' ? 'text-primary border-b-2 border-primary pb-1' : 'text-[#dae2fd]/60 hover:text-[#dae2fd] transition-colors'}`} href="/process">Process</a>
            <a class={`font-['Space_Grotesk'] tracking-tighter uppercase text-sm ${active === 'projects' ? 'text-primary border-b-2 border-primary pb-1' : 'text-[#dae2fd]/60 hover:text-[#dae2fd] transition-colors'}`} href="/projects">Projects</a>
            <a class="font-['Space_Grotesk'] tracking-tighter uppercase text-sm text-[#dae2fd]/60 hover:text-[#dae2fd] transition-colors" href="/#contact">Contact</a>
        </div>
        <div class="flex items-center gap-4">
            <a href="https://github.com/makanesha" target="_blank" title="GitHub Source" class="p-2 hover:bg-[#222a3d] transition-all duration-200 rounded text-[#38bdf8] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <button id="theme-toggle" title="Toggle Light/Dark Theme" class="p-2 hover:bg-[#222a3d] transition-all duration-200 rounded text-[#38bdf8] flex items-center justify-center">
                <span id="theme-icon" class="material-symbols-outlined text-xl">light_mode</span>
            </button>
        </div>
    </div>
</nav>

<script>
    const themeBtn = document.getElementById('theme-toggle');
    themeBtn?.addEventListener('click', () => {
        document.body.classList.toggle('theme-light');
        const icon = document.getElementById('theme-icon');
        if (icon) {
            icon.innerText = document.body.classList.contains('theme-light') ? 'dark_mode' : 'light_mode';
        }
    });
</script>
